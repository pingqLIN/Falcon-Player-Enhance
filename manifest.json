{
  "manifest_version": 3,
  "name": "Shield Pro - Ad Blocker & Player Enhancer",
  "version": "3.0.0",
  "description": "進階內容封鎖與媒體播放器優化 - 可調封鎖強度、訂閱過濾清單、白/黑名單、危險網站沙盒隔離",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback",
    "scripting",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/anti-antiblock.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/inject-blocker.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/cosmetic-filter.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/anti-popup.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content/styles.css",
        "content/player-overlay-fix.css"
      ],
      "js": [
        "content/element-picker.js",
        "content/player-detector.js",
        "content/player-enhancer.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "dashboard/dashboard.html",
    "open_in_tab": true
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ads_and_trackers",
        "enabled": true,
        "path": "rules/filter-rules.json"
      },
      {
        "id": "easylist",
        "enabled": true,
        "path": "rules/easylist.json"
      },
      {
        "id": "easyprivacy",
        "enabled": true,
        "path": "rules/easyprivacy.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/inject-blocker.js",
        "rules/noop.js",
        "sandbox/sandbox.html",
        "sandbox/sandbox.js",
        "popup-player/popup-player.html",
        "popup-player/popup-player.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "sandbox": {
    "pages": [
      "sandbox/sandbox.html"
    ]
  }
}