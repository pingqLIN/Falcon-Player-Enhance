{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "reviewStatus": {
      "type": "string",
      "enum": ["clear", "needs_patch", "invalid_targets_only", "needs_human_review"]
    },
    "summary": {
      "type": "string"
    },
    "actionableFailureCount": {
      "type": "integer",
      "minimum": 0
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "targetValidity": {
            "type": "string",
            "enum": ["valid", "invalid", "uncertain"]
          },
          "classification": {
            "type": "string",
            "enum": [
              "invalid_target",
              "player_not_loaded_yet",
              "host_permission_gap",
              "judge_heuristic_gap",
              "overlay_protection_failure",
              "popup_protection_failure",
              "regression_from_recent_change",
              "unknown_needs_human_review"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rootCause": {
            "type": "string"
          },
          "recommendedFixArea": {
            "type": "string",
            "enum": [
              "target_curation",
              "player_detection",
              "overlay_detection",
              "popup_blocking",
              "host_permissions",
              "timing_waits",
              "browser_judge",
              "human_review"
            ]
          },
          "nextStep": {
            "type": "string",
            "enum": [
              "drop_target",
              "retry_later",
              "tune_judge",
              "patch_extension",
              "human_review"
            ]
          },
          "shouldGeneratePatchBrief": {
            "type": "boolean"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "url",
          "targetValidity",
          "classification",
          "confidence",
          "rootCause",
          "recommendedFixArea",
          "nextStep",
          "shouldGeneratePatchBrief",
          "evidence"
        ]
      }
    }
  },
  "required": [
    "reviewStatus",
    "summary",
    "actionableFailureCount",
    "targets"
  ]
}
