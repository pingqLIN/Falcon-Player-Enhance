      "recentEvents": [
        { "type": "overlay_removed", "severity": 1.1, "confidence": 0.84, "source": "overlay-remover" },
        { "type": "blocked_popup", "severity": 1.0, "confidence": 0.91, "source": "anti-popup" }
      ],
      "expectation": {
        "minConfidence": 0.5,
        "requiredActions": ["tighten_popup_guard", "tune_overlay_scan"]
